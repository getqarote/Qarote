{
  "name": "qarote-api",
  "version": "2.0.0",
  "description": "Hono.js API for RabbitMQ Dashboard",
  "main": "dist/index.js",
  "keywords": [],
  "author": "La Griffe",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/index.ts",
    "dev:alert": "tsx watch --import ./src/instrument.ts src/workers/alert-monitor.ts",
    "dev:license": "tsx watch --import ./src/instrument.ts src/workers/license-monitor.ts",
    "dev:release-notifier": "tsx watch --import ./src/instrument.ts src/workers/release-notifier.ts",
    "dev:digest": "tsx watch --import ./src/instrument.ts src/ee/workers/digest-monitor.ts",
    "dev:firehose": "tsx watch --import ./src/instrument.ts src/ee/workers/firehose-monitor.ts",
    "build": "prisma generate && NODE_OPTIONS='--max-old-space-size=3072' tsc --project tsconfig.build.json && tsc-alias -f",
    "build:selfhosted": "DEPLOYMENT_MODE=selfhosted prisma generate && NODE_OPTIONS='--max-old-space-size=3072' tsc --project tsconfig.build.json && tsc-alias -f && tsx scripts/obfuscate-license.ts",
    "build:production": "pnpm run db:generate && pnpm run build && tsx scripts/obfuscate-license.ts",
    "start": "node --import ./dist/instrument.js dist/index.js",
    "start:alert": "node --import ./dist/instrument.js dist/workers/alert-monitor.js",
    "start:license": "node --import ./dist/instrument.js dist/workers/license-monitor.js",
    "start:release-notifier": "node --import ./dist/instrument.js dist/workers/release-notifier.js",
    "start:digest": "node --import ./dist/instrument.js dist/ee/workers/digest-monitor.js",
    "start:metrics": "node --import ./dist/instrument.js dist/ee/workers/metrics-monitor.js",
    "start:firehose": "node --import ./dist/instrument.js dist/ee/workers/firehose-monitor.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "db:migrate:dev": "prisma migrate dev && prisma generate",
    "db:studio": "prisma studio",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "start:production": "pnpm run db:migrate && pnpm run start",
    "seed:test": "tsx scripts/rabbitmq/seed-test-data.ts",
    "seed:users": "tsx scripts/rabbitmq/seed-test-data.ts --type=users",
    "seed:limits": "tsx scripts/rabbitmq/seed-test-data.ts --type=limits",
    "seed:email": "tsx scripts/rabbitmq/seed-test-data.ts --type=email",
    "seed:clean": "tsx scripts/rabbitmq/seed-test-data.ts --type=clean",
    "seed:publish": "tsx scripts/rabbitmq/seed-publish-messages.ts",
    "seed:consume": "tsx scripts/rabbitmq/seed-consume-messages.ts",
    "seed:all": "tsx scripts/rabbitmq/seed-all-servers.ts",
    "seed:email:send": "tsx scripts/email/resend/seed-email-verification-tests.ts",
    "email:dev": "email dev --dir ./scripts/email/emails --port 3001",
    "email:preview": "cd scripts/email/resend && email preview",
    "email:export": "cd scripts/email/resend && email export",
    "email:test": "tsx scripts/email/resend/test-email-rendering.ts",
    "email:test-cid": "tsx scripts/test-email-cid.ts",
    "webhook:test": "tsx scripts/webhook/test-webhook.ts",
    "stripe:set-up": "tsx scripts/stripe/setup-stripe.ts",
    "stripe:create": "tsx scripts/stripe/setup-stripe.ts create",
    "stripe:migrate": "tsx scripts/stripe/setup-stripe.ts migrate",
    "stripe:list": "tsx scripts/stripe/setup-stripe.ts list",
    "stripe:clean": "tsx scripts/stripe/setup-stripe.ts clean",
    "stripe:verify": "tsx scripts/stripe/setup-stripe.ts verify",
    "stripe:webhook": "tsx scripts/stripe/setup-stripe.ts webhook",
    "stripe:mode": "tsx scripts/stripe/setup-stripe.ts mode",
    "stripe:test": "tsx scripts/stripe/setup-stripe.ts test",
    "stripe:login": "stripe login",
    "webhook:secret": "stripe listen --print-secret",
    "test:smtp": "tsx scripts/email/nodemailer/test-smtp.ts",
    "test:smtp:ethereal": "tsx scripts/email/nodemailer/test-smtp.ts --ethereal",
    "notion:sync": "tsx scripts/notion/sync-users.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@better-auth/sso": "^1.5.4",
    "@hono/node-server": "^2.0.0",
    "@hono/trpc-server": "^0.4.2",
    "@notionhq/client": "^5.9.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@qarote/i18n": "workspace:*",
    "@react-email/components": "^1.0.7",
    "@react-email/render": "^2.0.4",
    "@sentry/node": "^10.42.0",
    "@sentry/profiling-node": "^10.42.0",
    "@trpc/server": "^11.11.0",
    "@types/react": "^19.2.0",
    "amqplib": "^0.10.8",
    "bcryptjs": "^3.0.2",
    "better-auth": "^1.5.4",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.14",
    "hono-rate-limiter": "^0.5.3",
    "jose": "^6.1.3",
    "nodemailer": "^8.0.5",
    "pg": "^8.19.0",
    "pino": "^10.3.1",
    "posthog-node": "^5.30.5",
    "react": "^19.2.4",
    "react-email": "^5.2.9",
    "resend": "^6.9.3",
    "semver": "^7.7.2",
    "stripe": "^20.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.7",
    "@types/cors": "^2.8.19",
    "@types/node": "^24",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.18.0",
    "@types/semver": "^7.7.0",
    "eslint": "^10.0.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
