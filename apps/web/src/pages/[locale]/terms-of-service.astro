---
import BaseLayout from "../../layouts/BaseLayout.astro";
import TermsOfServiceIsland from "../../components/TermsOfServiceIsland";
import { loadTranslations, t } from "../../lib/i18n-static";
import { getLocaleStaticPaths } from "../../lib/locales";

export const getStaticPaths = getLocaleStaticPaths;

const { locale } = Astro.params;
const legal = loadTranslations(locale, "legal");
const title = `${t(legal, "termsOfService.title")} - Qarote`;
---

<BaseLayout
  title={title}
  description="Terms of Service for Qarote - Learn about your rights and responsibilities when using our service."
  locale={locale}
  canonicalPath="/terms-of-service/"
>
  <TermsOfServiceIsland client:load />
</BaseLayout>
