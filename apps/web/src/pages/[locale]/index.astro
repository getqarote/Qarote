---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LandingIsland from "../../components/LandingIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { faqSchema } from "../../lib/faq-schema";
import { getLocaleStaticPaths } from "../../lib/locales";

export const getStaticPaths = getLocaleStaticPaths;

const { locale } = Astro.params;
const landing = loadTranslations(locale, "landing");
const resources = loadAllTranslations(locale);
---

<BaseLayout
  title={t(landing, "seo.title")}
  description={t(landing, "seo.description")}
  locale={locale}
  canonicalPath="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <LandingIsland locale={locale} resources={resources} client:load />
</BaseLayout>
