---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LandingIsland from "../../components/LandingIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/faq-schema";
import { getLocaleStaticPaths } from "../../lib/locales";

export const getStaticPaths = getLocaleStaticPaths;

const { locale } = Astro.params;
const landing = loadTranslations(locale, "landing");
const faq = loadTranslations(locale, "faq");
const resources = loadAllTranslations(locale);
const faqSchema = buildFaqSchema(faq);

const allPosts = await getCollection("blog");
const blogPosts = allPosts
  .filter((p) => !p.id.includes("/"))
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3)
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    description: p.data.description,
    publishedAt: p.data.publishedAt,
    tags: p.data.tags,
    readingTimeMin: p.data.readingTimeMin,
  }));
---

<BaseLayout
  title={t(landing, "seo.title")}
  description={t(landing, "seo.description")}
  locale={locale}
  canonicalPath="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <LandingIsland locale={locale} resources={resources} blogPosts={blogPosts} client:load />
</BaseLayout>
