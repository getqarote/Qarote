---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AboutIsland from "../../components/AboutIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildAboutSchema } from "../../lib/about-schema";
import { getLocaleStaticPaths } from "../../lib/locales";

export const getStaticPaths = getLocaleStaticPaths;

const { locale } = Astro.params;
const about = loadTranslations(locale, "about");
const resources = loadAllTranslations(locale);
const personSchemas = buildAboutSchema(about);
---

<BaseLayout
  title={t(about, "seo.title")}
  description={t(about, "seo.description")}
  locale={locale}
  canonicalPath="/about/"
>
  <Fragment slot="head">
    {personSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>
  <AboutIsland locale={locale} resources={resources} client:load />
</BaseLayout>
