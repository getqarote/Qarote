---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { FeaturesDigestIsland } from "../../../components/FeaturesDigestIsland";
import { loadTranslations, loadAllTranslations, t } from "../../../lib/i18n-static";
import { getLocaleStaticPaths } from "../../../lib/locales";
import { SUPPORTED_LOCALES, type SupportedLocale } from "@qarote/i18n";
import { buildFaqSchema } from "../../../lib/schema";

export const getStaticPaths = getLocaleStaticPaths;

const rawLocale = Astro.params.locale;
if (!rawLocale || !SUPPORTED_LOCALES.includes(rawLocale as SupportedLocale)) {
  return Astro.redirect("/");
}
const locale = rawLocale as SupportedLocale;
const digest = loadTranslations(locale, "features-digest");
const resources = { ...loadAllTranslations(locale), "features-digest": digest };
const faqSchema = buildFaqSchema(digest);
---

<BaseLayout
  title={t(digest, "seo.title")}
  description={t(digest, "seo.description")}
  locale={locale}
  canonicalPath="/features/digest/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesDigestIsland locale={locale} resources={resources} client:load />
</BaseLayout>
