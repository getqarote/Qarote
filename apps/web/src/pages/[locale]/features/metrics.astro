---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { FeaturesMetricsIsland } from "../../../components/FeaturesMetricsIsland";
import { loadTranslations, loadAllTranslations, t } from "../../../lib/i18n-static";
import { getLocaleStaticPaths } from "../../../lib/locales";
import { SUPPORTED_LOCALES, type SupportedLocale } from "@qarote/i18n";
import { buildFaqSchema } from "../../../lib/schema";

export const getStaticPaths = getLocaleStaticPaths;

const rawLocale = Astro.params.locale;
if (!rawLocale || !SUPPORTED_LOCALES.includes(rawLocale as SupportedLocale)) {
  return Astro.redirect("/");
}
const locale = rawLocale as SupportedLocale;
const metrics = loadTranslations(locale, "features-metrics");
const resources = { ...loadAllTranslations(locale), "features-metrics": metrics };
const faqSchema = buildFaqSchema(metrics);
---

<BaseLayout
  title={t(metrics, "seo.title")}
  description={t(metrics, "seo.description")}
  locale={locale}
  canonicalPath="/features/metrics/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesMetricsIsland locale={locale} resources={resources} client:load />
</BaseLayout>
