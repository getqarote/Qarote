---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { FeaturesMessageTracingIsland } from "../../../components/FeaturesMessageTracingIsland";
import { loadTranslations, loadAllTranslations, t } from "../../../lib/i18n-static";
import { getLocaleStaticPaths } from "../../../lib/locales";
import { SUPPORTED_LOCALES, type SupportedLocale } from "@qarote/i18n";
import { buildFaqSchema } from "../../../lib/schema";

export const getStaticPaths = getLocaleStaticPaths;

const rawLocale = Astro.params.locale;
if (!rawLocale || !SUPPORTED_LOCALES.includes(rawLocale as SupportedLocale)) {
  return Astro.redirect("/");
}
const locale = rawLocale as SupportedLocale;
const messageTracing = loadTranslations(locale, "features-message-tracing");
const resources = { ...loadAllTranslations(locale), "features-message-tracing": messageTracing };
const faqSchema = buildFaqSchema(messageTracing);
---

<BaseLayout
  title={t(messageTracing, "seo.title")}
  description={t(messageTracing, "seo.description")}
  locale={locale}
  canonicalPath="/features/message-tracing/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesMessageTracingIsland locale={locale} resources={resources} client:load />
</BaseLayout>
