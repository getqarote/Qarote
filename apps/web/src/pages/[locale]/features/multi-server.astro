---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { FeaturesMultiServerIsland } from "../../../components/FeaturesMultiServerIsland";
import { loadTranslations, loadAllTranslations, t } from "../../../lib/i18n-static";
import { getLocaleStaticPaths } from "../../../lib/locales";
import { SUPPORTED_LOCALES, type SupportedLocale } from "@qarote/i18n";
import { buildFaqSchema } from "../../../lib/schema";

export const getStaticPaths = getLocaleStaticPaths;

const rawLocale = Astro.params.locale;
if (!rawLocale || !SUPPORTED_LOCALES.includes(rawLocale as SupportedLocale)) {
  return Astro.redirect("/");
}
const locale = rawLocale as SupportedLocale;
const multiServer = loadTranslations(locale, "features-multi-server");
const resources = { ...loadAllTranslations(locale), "features-multi-server": multiServer };
const faqSchema = buildFaqSchema(multiServer);
---

<BaseLayout
  title={t(multiServer, "seo.title")}
  description={t(multiServer, "seo.description")}
  locale={locale}
  canonicalPath="/features/multi-server/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesMultiServerIsland locale={locale} resources={resources} client:load />
</BaseLayout>
