---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { FeaturesIncidentDiagnosisIsland } from "../../../components/FeaturesIncidentDiagnosisIsland";
import { loadTranslations, loadAllTranslations, t } from "../../../lib/i18n-static";
import { getLocaleStaticPaths } from "../../../lib/locales";
import { SUPPORTED_LOCALES, type SupportedLocale } from "@qarote/i18n";
import { buildFaqSchema } from "../../../lib/schema";

export const getStaticPaths = getLocaleStaticPaths;

const rawLocale = Astro.params.locale;
if (!rawLocale || !SUPPORTED_LOCALES.includes(rawLocale as SupportedLocale)) {
  return Astro.redirect("/");
}
const locale = rawLocale as SupportedLocale;
const incidentDiagnosis = loadTranslations(locale, "features-incident-diagnosis");
const resources = { ...loadAllTranslations(locale), "features-incident-diagnosis": incidentDiagnosis };
const faqSchema = buildFaqSchema(incidentDiagnosis);
---

<BaseLayout
  title={t(incidentDiagnosis, "seo.title")}
  description={t(incidentDiagnosis, "seo.description")}
  locale={locale}
  canonicalPath="/features/incident-diagnosis/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesIncidentDiagnosisIsland locale={locale} resources={resources} client:load />
</BaseLayout>
