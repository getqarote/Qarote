---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { FeaturesAnalyticsIsland } from "../../../components/FeaturesAnalyticsIsland";
import { loadTranslations, loadAllTranslations, t } from "../../../lib/i18n-static";
import { getLocaleStaticPaths } from "../../../lib/locales";
import { SUPPORTED_LOCALES, type SupportedLocale } from "@qarote/i18n";
import { buildFaqSchema } from "../../../lib/schema";

export const getStaticPaths = getLocaleStaticPaths;

const rawLocale = Astro.params.locale;
if (!rawLocale || !SUPPORTED_LOCALES.includes(rawLocale as SupportedLocale)) {
  return Astro.redirect("/");
}
const locale = rawLocale as SupportedLocale;
const analytics = loadTranslations(locale, "features-analytics");
const resources = { ...loadAllTranslations(locale), "features-analytics": analytics };
const faqSchema = buildFaqSchema(analytics);
---

<BaseLayout
  title={t(analytics, "seo.title")}
  description={t(analytics, "seo.description")}
  locale={locale}
  canonicalPath="/features/analytics/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesAnalyticsIsland locale={locale} resources={resources} client:load />
</BaseLayout>
