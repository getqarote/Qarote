---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PrivacyPolicyIsland from "../../components/PrivacyPolicyIsland";
import { loadTranslations, t } from "../../lib/i18n-static";
import { getLocaleStaticPaths } from "../../lib/locales";

export const getStaticPaths = getLocaleStaticPaths;

const { locale } = Astro.params;
const legal = loadTranslations(locale, "legal");
const title = `${t(legal, "privacyPolicy.title")} - Qarote`;
---

<BaseLayout
  title={title}
  description="Privacy Policy for Qarote - Learn how we collect, use, and protect your data."
  locale={locale}
  canonicalPath="/privacy-policy/"
>
  <PrivacyPolicyIsland client:load />
</BaseLayout>
