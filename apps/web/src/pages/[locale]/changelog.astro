---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ChangelogIsland from "../../components/ChangelogIsland";
import { loadAllTranslations } from "../../lib/i18n-static";
import { getLocaleStaticPaths } from "../../lib/locales";

export const getStaticPaths = getLocaleStaticPaths;

const { locale } = Astro.params;
const resources = loadAllTranslations(locale);
---

<BaseLayout
  title="Changelog - Qarote"
  description="See what's new in Qarote. Browse the latest features, improvements, and bug fixes."
  locale={locale}
  canonicalPath="/changelog/"
>
  <ChangelogIsland locale={locale} resources={resources} client:load />
</BaseLayout>
