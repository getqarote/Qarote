---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChangelogIsland from "../components/ChangelogIsland";
import { loadAllTranslations } from "../lib/i18n-static";

const resources = loadAllTranslations("en");
---

<BaseLayout
  title="Changelog - Qarote RabbitMQ Dashboard"
  description="See what's new in Qarote. Browse the latest features, improvements, and bug fixes."
  canonicalPath="/changelog/"
>
  <ChangelogIsland resources={resources} client:load />
</BaseLayout>
