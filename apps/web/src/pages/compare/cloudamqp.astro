---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { CompareCloudAMQPIsland } from "../../components/CompareIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";

const compare = loadTranslations("en", "compare-cloudamqp");
const resources = { ...loadAllTranslations("en"), "compare-cloudamqp": compare };

const allPosts = await getCollection("blog");
const blogPosts = allPosts
  .filter((p) => !p.id.includes("/"))
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3)
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    description: p.data.description,
    publishedAt: p.data.publishedAt,
    tags: p.data.tags,
    readingTimeMin: p.data.readingTimeMin,
  }));

const cloudamqpSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "CloudAMQP",
  url: "https://www.cloudamqp.com/",
  applicationCategory: "DeveloperApplication",
  description: "Managed RabbitMQ hosting service with a built-in monitoring dashboard.",
};

const faqSchema = buildFaqSchema(compare);
---

<BaseLayout
  title={t(compare, "seo.title")}
  description={t(compare, "seo.description")}
  locale="en"
  canonicalPath="/compare/cloudamqp/"
  image="https://qarote.io/images/qarote_card.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(cloudamqpSchema)} />
  </Fragment>
  <CompareCloudAMQPIsland locale="en" resources={resources} blogPosts={blogPosts} client:load />
</BaseLayout>
