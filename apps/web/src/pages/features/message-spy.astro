---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesMessageSpyIsland } from "../../components/FeaturesMessageSpyIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";

const messageSpy = loadTranslations("en", "features-message-spy");
const resources = { ...loadAllTranslations("en"), "features-message-spy": messageSpy };
const faqSchema = buildFaqSchema(messageSpy);
---

<BaseLayout
  title={t(messageSpy, "seo.title")}
  description={t(messageSpy, "seo.description")}
  locale="en"
  canonicalPath="/features/message-spy/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesMessageSpyIsland locale="en" resources={resources} client:load />
</BaseLayout>
