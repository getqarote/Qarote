---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesMessageSpyIsland } from "../../components/FeaturesMessageSpyIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";
import { DEFAULT_LOCALE } from "@qarote/i18n";

const messageSpy = loadTranslations(DEFAULT_LOCALE, "features-message-spy");
const resources = { ...loadAllTranslations(DEFAULT_LOCALE), "features-message-spy": messageSpy };
const faqSchema = buildFaqSchema(messageSpy);
---

<BaseLayout
  title={t(messageSpy, "seo.title")}
  description={t(messageSpy, "seo.description")}
  locale={DEFAULT_LOCALE}
  canonicalPath="/features/message-spy/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesMessageSpyIsland locale={DEFAULT_LOCALE} resources={resources} client:load />
</BaseLayout>
