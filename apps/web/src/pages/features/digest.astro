---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesDigestIsland } from "../../components/FeaturesDigestIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";

const digest = loadTranslations("en", "features-digest");
const resources = { ...loadAllTranslations("en"), "features-digest": digest };
const faqSchema = buildFaqSchema(digest);
---

<BaseLayout
  title={t(digest, "seo.title")}
  description={t(digest, "seo.description")}
  locale="en"
  canonicalPath="/features/digest/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesDigestIsland locale="en" resources={resources} client:load />
</BaseLayout>
