---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesLiveMonitoringIsland } from "../../components/FeaturesLiveMonitoringIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";
import { DEFAULT_LOCALE } from "@qarote/i18n";

const liveMonitoring = loadTranslations(DEFAULT_LOCALE, "features-live-monitoring");
const resources = { ...loadAllTranslations(DEFAULT_LOCALE), "features-live-monitoring": liveMonitoring };
const faqSchema = buildFaqSchema(liveMonitoring);
---

<BaseLayout
  title={t(liveMonitoring, "seo.title")}
  description={t(liveMonitoring, "seo.description")}
  locale={DEFAULT_LOCALE}
  canonicalPath="/features/live-monitoring/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesLiveMonitoringIsland locale={DEFAULT_LOCALE} resources={resources} client:load />
</BaseLayout>
