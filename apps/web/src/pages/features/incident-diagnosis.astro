---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesIncidentDiagnosisIsland } from "../../components/FeaturesIncidentDiagnosisIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";

const incidentDiagnosis = loadTranslations("en", "features-incident-diagnosis");
const resources = { ...loadAllTranslations("en"), "features-incident-diagnosis": incidentDiagnosis };
const faqSchema = buildFaqSchema(incidentDiagnosis);
---

<BaseLayout
  title={t(incidentDiagnosis, "seo.title")}
  description={t(incidentDiagnosis, "seo.description")}
  locale="en"
  canonicalPath="/features/incident-diagnosis/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesIncidentDiagnosisIsland locale="en" resources={resources} client:load />
</BaseLayout>
