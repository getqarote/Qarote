---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesIncidentDiagnosisIsland } from "../../components/FeaturesIncidentDiagnosisIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";
import { DEFAULT_LOCALE } from "@qarote/i18n";

const incidentDiagnosis = loadTranslations(DEFAULT_LOCALE, "features-incident-diagnosis");
const resources = { ...loadAllTranslations(DEFAULT_LOCALE), "features-incident-diagnosis": incidentDiagnosis };
const faqSchema = buildFaqSchema(incidentDiagnosis);
---

<BaseLayout
  title={t(incidentDiagnosis, "seo.title")}
  description={t(incidentDiagnosis, "seo.description")}
  locale={DEFAULT_LOCALE}
  canonicalPath="/features/incident-diagnosis/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesIncidentDiagnosisIsland locale={DEFAULT_LOCALE} resources={resources} client:load />
</BaseLayout>
