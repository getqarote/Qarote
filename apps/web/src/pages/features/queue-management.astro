---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesQueueManagementIsland } from "../../components/FeaturesQueueManagementIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";
import { DEFAULT_LOCALE } from "@qarote/i18n";

const queueManagement = loadTranslations(DEFAULT_LOCALE, "features-queue-management");
const resources = { ...loadAllTranslations(DEFAULT_LOCALE), "features-queue-management": queueManagement };
const faqSchema = buildFaqSchema(queueManagement);
---

<BaseLayout
  title={t(queueManagement, "seo.title")}
  description={t(queueManagement, "seo.description")}
  locale={DEFAULT_LOCALE}
  canonicalPath="/features/queue-management/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesQueueManagementIsland locale={DEFAULT_LOCALE} resources={resources} client:load />
</BaseLayout>
