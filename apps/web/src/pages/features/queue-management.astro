---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesQueueManagementIsland } from "../../components/FeaturesQueueManagementIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";

const queueManagement = loadTranslations("en", "features-queue-management");
const resources = { ...loadAllTranslations("en"), "features-queue-management": queueManagement };
const faqSchema = buildFaqSchema(queueManagement);
---

<BaseLayout
  title={t(queueManagement, "seo.title")}
  description={t(queueManagement, "seo.description")}
  locale="en"
  canonicalPath="/features/queue-management/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesQueueManagementIsland locale="en" resources={resources} client:load />
</BaseLayout>
