---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesMultiServerIsland } from "../../components/FeaturesMultiServerIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";

const multiServer = loadTranslations("en", "features-multi-server");
const resources = { ...loadAllTranslations("en"), "features-multi-server": multiServer };
const faqSchema = buildFaqSchema(multiServer);
---

<BaseLayout
  title={t(multiServer, "seo.title")}
  description={t(multiServer, "seo.description")}
  locale="en"
  canonicalPath="/features/multi-server/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesMultiServerIsland locale="en" resources={resources} client:load />
</BaseLayout>
