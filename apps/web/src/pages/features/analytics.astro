---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesAnalyticsIsland } from "../../components/FeaturesAnalyticsIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";

const analytics = loadTranslations("en", "features-analytics");
const resources = { ...loadAllTranslations("en"), "features-analytics": analytics };
const faqSchema = buildFaqSchema(analytics);
---

<BaseLayout
  title={t(analytics, "seo.title")}
  description={t(analytics, "seo.description")}
  locale="en"
  canonicalPath="/features/analytics/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesAnalyticsIsland locale="en" resources={resources} client:load />
</BaseLayout>
