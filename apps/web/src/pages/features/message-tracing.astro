---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesMessageTracingIsland } from "../../components/FeaturesMessageTracingIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";

const messageTracing = loadTranslations("en", "features-message-tracing");
const resources = { ...loadAllTranslations("en"), "features-message-tracing": messageTracing };
const faqSchema = buildFaqSchema(messageTracing);
---

<BaseLayout
  title={t(messageTracing, "seo.title")}
  description={t(messageTracing, "seo.description")}
  locale="en"
  canonicalPath="/features/message-tracing/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesMessageTracingIsland locale="en" resources={resources} client:load />
</BaseLayout>
