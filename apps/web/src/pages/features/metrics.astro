---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FeaturesMetricsIsland } from "../../components/FeaturesMetricsIsland";
import { loadTranslations, loadAllTranslations, t } from "../../lib/i18n-static";
import { buildFaqSchema } from "../../lib/schema";

const metrics = loadTranslations("en", "features-metrics");
const resources = { ...loadAllTranslations("en"), "features-metrics": metrics };
const faqSchema = buildFaqSchema(metrics);
---

<BaseLayout
  title={t(metrics, "seo.title")}
  description={t(metrics, "seo.description")}
  locale="en"
  canonicalPath="/features/metrics/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <FeaturesMetricsIsland locale="en" resources={resources} client:load />
</BaseLayout>
