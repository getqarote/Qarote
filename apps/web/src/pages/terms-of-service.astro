---
import BaseLayout from "../layouts/BaseLayout.astro";
import TermsOfServiceIsland from "../components/TermsOfServiceIsland";
import { loadAllTranslations } from "../lib/i18n-static";

const resources = loadAllTranslations("en");
---

<BaseLayout
  title="Terms of Service - Qarote RabbitMQ Monitoring"
  description="Terms of Service for Qarote - Learn about your rights and responsibilities when using our service."
  canonicalPath="/terms-of-service/"
>
  <TermsOfServiceIsland resources={resources} client:load />
</BaseLayout>
