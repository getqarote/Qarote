---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SecurityIsland } from "../components/SecurityIsland";
import { loadAllTranslations, loadTranslations, t } from "../lib/i18n-static";

const security = loadTranslations("en", "security");
const resources = { ...loadAllTranslations("en"), security };
---

<BaseLayout
  title={t(security, "seo.title")}
  description={t(security, "seo.description")}
  canonicalPath="/security/"
>
  <SecurityIsland resources={resources} client:load />
</BaseLayout>
