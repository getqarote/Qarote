---
import BaseLayout from "../layouts/BaseLayout.astro";
import LandingIsland from "../components/LandingIsland";
import { loadTranslations, loadAllTranslations, t } from "../lib/i18n-static";
import { buildFaqSchema } from "../lib/faq-schema";

const landing = loadTranslations("en", "landing");
const faq = loadTranslations("en", "faq");
const resources = loadAllTranslations("en");
const faqSchema = buildFaqSchema(faq);
---

<BaseLayout
  title={t(landing, "seo.title")}
  description={t(landing, "seo.description")}
  canonicalPath="/"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <LandingIsland resources={resources} client:load />
</BaseLayout>
