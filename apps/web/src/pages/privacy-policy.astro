---
import BaseLayout from "../layouts/BaseLayout.astro";
import PrivacyPolicyIsland from "../components/PrivacyPolicyIsland";
import { loadAllTranslations } from "../lib/i18n-static";

const resources = loadAllTranslations("en");
---

<BaseLayout
  title="Privacy Policy - Qarote"
  description="Privacy Policy for Qarote - Learn how we collect, use, and protect your data."
  canonicalPath="/privacy-policy/"
>
  <PrivacyPolicyIsland resources={resources} client:load />
</BaseLayout>
